# n8n runtime
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
GENERIC_TIMEZONE=UTC

# Paths
N8N_DATA_PATH=./data/n8n
NOTES_HOST_PATH=./notes_export
NOTES_VAULT_ROOT=/data/notes

# Granola automation config surface
GRANOLA_API_BASE_URL=https://api.granola.ai/v1
GRANOLA_API_TOKEN=replace_me
GRANOLA_EXPORT_FOLDERS=Exports/Markdown,Exports/1to1,Exports/Meetings
INCLUDE_TRANSCRIPT=true
EXPORT_MODE=api
GRANOLA_BOOTSTRAP_UPDATED_AFTER=2026-04-01T00:00:00Z
DEFAULT_TIMEZONE=UTC
FILE_NAMING_MODE=stable_note_id
# JSON object string. Keys are Granola folder names, values are vault subpaths under NOTES_VAULT_ROOT.
OPTIONAL_SUBPATH_MAP={"Exports/1to1":"meetings/1to1","Exports/Meetings":"meetings/general","Exports/Markdown":"meetings/misc"}
